{
  "name": "zeno",
  "version": "0.1.0",
  "private": true,
  "description": "Zeno subscription intelligence monorepo.",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @zeno/mobile run start",
    "dev:api": "npm --workspace @zeno/api run dev",
    "dev:web": "npm --workspace @zeno/web run dev",
    "build": "npm run typecheck && npm --workspace @zeno/web run build",
    "typecheck": "npm run typecheck:refs && npm --workspace @zeno/mobile run typecheck && npm --workspace @zeno/web run typecheck",
    "typecheck:refs": "tsc -b --pretty false",
    "lint": "eslint . && npm --workspace @zeno/web run lint && npm --workspace @zeno/mobile run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-api.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "sharp": "^0.35.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.0.15"
  }
}
