# Zeno API — environment variables.
# Copy to `.env` (gitignored) and fill in. Every integration is optional: when a
# key is absent the related feature reports "unconfigured" and the app falls back
# gracefully (no crashes, no fake data).

# ── AI spend coach (#32) ───────────────────────────────────────────────
# Powers POST /api/v1/coach. With no provider key set, the coach screen shows
# on-device rule-based insights only.
#
# Provider auto-selects: Anthropic if ANTHROPIC_API_KEY is set, else Groq if
# GROQ_API_KEY is set. Force it with COACH_PROVIDER=anthropic|groq.
#
# Option A — Groq (free, OpenAI-compatible): get a key at console.groq.com
GROQ_API_KEY=
# Option B — Anthropic / Claude: get a key at console.anthropic.com
ANTHROPIC_API_KEY=
#
# COACH_PROVIDER=groq
# Default model depends on provider (groq: llama-3.3-70b-versatile,
# anthropic: claude-opus-4-8). Override — must match the active provider:
# AI_COACH_MODEL=llama-3.3-70b-versatile
# Any OpenAI-compatible endpoint (OpenRouter, Together, local) via groq + base url:
# COACH_BASE_URL=https://api.groq.com/openai/v1

# ── Billing / entitlements (RevenueCat) ────────────────────────────────
REVENUECAT_SECRET_KEY=
REVENUECAT_API=https://api.revenuecat.com/v1
REVENUECAT_WEBHOOK_AUTH=

# ── Bank connect (Plaid) ───────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── CORS / runtime ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=
# DEMO_LOGIN_PASSWORD=
# NODE_ENV=development
