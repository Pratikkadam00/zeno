# Zeno API — environment variables.
# Copy to `.env` (gitignored) and fill in. Every integration is optional: when a
# key is absent the related feature reports "unconfigured" and the app falls back
# gracefully (no crashes, no fake data).

# ── AI spend coach (#32) ───────────────────────────────────────────────
# Powers POST /api/v1/coach. With no provider key set, the coach screen shows
# on-device rule-based insights only.
#
# Provider auto-selects: Anthropic if ANTHROPIC_API_KEY is set, else Groq if
# GROQ_API_KEY is set. Force it with COACH_PROVIDER=anthropic|groq.
#
# Option A — Groq (free, OpenAI-compatible): get a key at console.groq.com
GROQ_API_KEY=
# Option B — Anthropic / Claude: get a key at console.anthropic.com
ANTHROPIC_API_KEY=
#
# COACH_PROVIDER=groq
# Default model depends on provider (groq: llama-3.3-70b-versatile,
# anthropic: claude-opus-4-8). Override — must match the active provider:
# AI_COACH_MODEL=llama-3.3-70b-versatile
# Any OpenAI-compatible endpoint (OpenRouter, Together, local) via groq + base url:
# COACH_BASE_URL=https://api.groq.com/openai/v1

# ── Billing / entitlements (RevenueCat) ────────────────────────────────
REVENUECAT_SECRET_KEY=
REVENUECAT_WEBHOOK_AUTH=

# ── Bank connect (Plaid) ───────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Persistence (optional) ─────────────────────────────────────────────
# Postgres connection string. When set, the in-memory stores (cloud sync,
# entitlements, households, logged-in sessions) are mirrored to Postgres and
# replayed on boot, so a restart/redeploy no longer drops them. When UNSET the
# API runs fully in-memory exactly as before (fine for local dev + tests).
# DATABASE_URL=postgres://user:pass@host:5432/zeno
# Set to "disable" only for a local Postgres without TLS (hosted PG needs TLS):
# DATABASE_SSL=disable
# Optional: shared rate-limit store. With REDIS_URL set, the rate limiter counts
# across instances (the in-memory default is per-process). Inert when unset.
# REDIS_URL=redis://default:password@host:6379
# Optional: POST 5xx server errors to this webhook (Slack/Discord/any collector)
# for alerting. Sends route pattern + message + request id only — no PII. Inert when unset.
# MONITORING_WEBHOOK_URL=https://hooks.example.com/...
# 32-byte key (64 hex chars or base64) that encrypts secrets at rest — required
# for Plaid bank-access tokens to be persisted at all (without it they stay
# in-memory). Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# STORAGE_ENCRYPTION_KEY=

# ── CORS / runtime ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=
# DEMO_LOGIN_PASSWORD=
# NODE_ENV=development
# How many proxy hops to trust for client-IP resolution (rate-limit keying).
# Behind a host like Render the default (1 in production) is correct; set
# explicitly if there are more proxy layers. Never effectively "trust all".
# TRUST_PROXY_HOPS=1
