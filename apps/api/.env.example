# Zeno API — environment variables.
# Copy to `.env` (gitignored) and fill in. Every integration is optional: when a
# key is absent the related feature reports "unconfigured" and the app falls back
# gracefully (no crashes, no fake data).

# ── AI spend coach (#32) ───────────────────────────────────────────────
# Powers POST /api/v1/coach. Without it, the coach screen shows on-device
# rule-based insights only.
ANTHROPIC_API_KEY=
# Optional: pick a cheaper model to stretch a free trial. Default: claude-opus-4-8.
# AI_COACH_MODEL=claude-haiku-4-5

# ── Billing / entitlements (RevenueCat) ────────────────────────────────
REVENUECAT_SECRET_KEY=
REVENUECAT_API=https://api.revenuecat.com/v1
REVENUECAT_WEBHOOK_AUTH=

# ── Bank connect (Plaid) ───────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── CORS / runtime ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=
# DEMO_LOGIN_PASSWORD=
# NODE_ENV=development
