NODE_ENV=development
API_PORT=8787
API_HOST=127.0.0.1
PUBLIC_API_BASE_URL=http://127.0.0.1:8787/api/v1
MAGIC_LINK_REDIRECT_URL=zeno://auth/verify
# Comma-separated browser origins allowed to call the API (empty = mobile/no-Origin clients only).
CORS_ALLOWED_ORIGINS=
DEMO_LOGIN_ENABLED=true
DEMO_LOGIN_EMAIL=demo@zeno.local
# Required to enable demo login. Pick your own value; never commit a real one.
DEMO_LOGIN_PASSWORD=
# Dev-only escape hatch: accept Apple/Google tokens without signature verification
# when no OAuth client IDs are configured. Has no effect in production.
ALLOW_UNVERIFIED_OAUTH_TOKENS=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zeno <login@zeno.app>
JWT_ISSUER=zeno-api
JWT_AUDIENCE=zeno-mobile
JWT_KEY_ID=zeno-rs256-prod
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
APPLE_CLIENT_ID=
APPLE_BUNDLE_ID=app.zeno.mobile
GOOGLE_EXPO_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
# Gmail receipt scanning OAuth. Get this from https://console.cloud.google.com.
# Enable Gmail API, then create OAuth 2.0 credentials of type ANDROID + iOS
# (NATIVE / public clients) — NOT a "Web application" client. Native clients have
# NO client secret; the app uses PKCE. Never put an OAuth client secret in an
# EXPO_PUBLIC_* var — it is inlined into the app bundle and extractable.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Native per-platform OAuth client IDs (used on real device builds; no secret).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
PLAUSIBLE_DOMAIN=
SENTRY_DSN=
REVENUECAT_API_KEY=
STRIPE_SECRET_KEY=
ANTHROPIC_API_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
MX_CLIENT_ID=
MX_API_KEY=
