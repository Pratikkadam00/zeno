{
  "files": [],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/service-catalog" },
    { "path": "./apps/api" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@subradar/shared": ["packages/shared/src/index.ts"],
      "@subradar/service-catalog": ["packages/service-catalog/src/index.ts"]
    },
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}
